# ──────────────────────────────────────────────────────────────────────────
# PPlus AI Sync Tool — environment
# Copy to .env.local and fill in.
# ──────────────────────────────────────────────────────────────────────────

# Storage backend. Leave unset to use embedded PGlite at ~/.pplus-ai-sync/db
# (no install required). Set to a real Postgres URL for production.
#   DATABASE_URL=pglite:///absolute/path/to/db     # embedded Postgres
#   DATABASE_URL=postgres://user:pass@host/db      # real Postgres
# DATABASE_URL=

# AI runs via the Claude Agent SDK, which invokes the local `claude` CLI.
# If you're already signed in with `claude` (any subscription or API key), the
# tool just works — no ANTHROPIC_API_KEY needed here. Set this only if you
# want to force a specific key for the spawned Claude process.
# ANTHROPIC_API_KEY=

# Claude model. Default is the latest Opus.
ANTHROPIC_MODEL=claude-opus-4-7

# 32-byte key (base64) used to encrypt stored PPlus env credentials at rest.
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PPLUS_SYNC_MASTER_KEY=

# NextAuth secret for the single-operator local login.
# Run: openssl rand -base64 32
AUTH_SECRET=

# Optional: default concurrency for outbound PPlus API calls per target.
PPLUS_SYNC_CONCURRENCY=4
