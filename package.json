{
  "name": "pplus-ai-sync-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone AI-powered configuration sync tool for PPlus instances, powered by Claude.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bootstrap": "bash scripts/setup.sh",
    "setup": "bash scripts/setup.sh",
    "start": "node scripts/dev.mjs",
    "dev": "node scripts/dev.mjs",
    "banner": "node scripts/banner.mjs",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @pplus-sync/db exec drizzle-kit generate --name init",
    "db:migrate": "pnpm --filter @pplus-sync/db migrate",
    "db:seed": "pnpm --filter @pplus-sync/db seed",
    "db:reset": "rm -rf ~/.pplus-ai-sync/db"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1"
  }
}
