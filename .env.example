# ──────────────────────────────────────────────────────────────────────────
# PPlus AI Sync Tool — environment
# Copy to .env.local and fill in.
# ──────────────────────────────────────────────────────────────────────────

# Local Postgres used for runs, snapshots, mappings, audit.
# Defaults to the docker-compose service; swap for any reachable Postgres URL.
DATABASE_URL=postgres://pplus_sync:pplus_sync@localhost:5433/pplus_sync

# Anthropic API key — required for AI mapping / formula rewrite / diff explain.
# The app boots without this; AI features stay disabled until it's set.
ANTHROPIC_API_KEY=

# Claude model. Default is the latest Opus.
ANTHROPIC_MODEL=claude-opus-4-7

# 32-byte key (base64) used to encrypt stored PPlus env credentials at rest.
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PPLUS_SYNC_MASTER_KEY=

# NextAuth secret for the single-operator local login.
# Run: openssl rand -base64 32
AUTH_SECRET=

# Optional: default concurrency for outbound PPlus API calls per target.
PPLUS_SYNC_CONCURRENCY=4
